# Supabase
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Database (Supabase connection pooler - asyncpg 형식)
# Supabase Dashboard → Settings → Database → Connection string → URI (asyncpg 형식)
# postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Redis (Railway Redis addon URL)
REDIS_URL=redis://[railway-redis-url]

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Frontend URL (Vercel 배포 후 설정 - CORS 허용)
FRONTEND_URL=https://your-app.vercel.app

# Port (Railway가 자동 주입, 기본값 8000)
PORT=8000
